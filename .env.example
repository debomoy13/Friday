# Friday AI Assistant Environment Variables

# The API key for Google Gemini model access (Required)
GEMINI_API_KEY=your_gemini_api_key_here

# Port to run the local server on (Default: 8000)
PORT=8000

# User name Friday will use to address you (e.g. Sir, Boss, your name)
USER_NAME=Sir

# Assistant name
ASSISTANT_NAME=Friday

# Safety enforcement level: high (confirm all actions), medium (confirm dangerous actions), low (no confirmation)
SAFETY_LEVEL=medium
